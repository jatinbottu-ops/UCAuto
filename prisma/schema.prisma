generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  admin
}

enum VehicleStatus {
  available
  limited
  rented
  waitlist
}

enum VehicleType {
  sedan
  suv
  minivan
  truck
  compact
}

enum FuelType {
  gas
  hybrid
  electric
}

enum Transmission {
  automatic
  manual
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  approved
  payment_pending
  active
  waitlisted
  rejected
}

enum PaymentType {
  deposit
  reservation_fee
  first_period
  recurring
}

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
}

model User {
  id                    String    @id @default(uuid())
  stackAuthId           String?   @unique
  email                 String    @unique
  firstName             String
  lastName              String
  phone                 String?
  dateOfBirth           DateTime?
  role                  UserRole  @default(customer)
  address               Json?
  idDocumentKey         String?
  idVerified            Boolean   @default(false)
  idVerifiedAt          DateTime?
  insuranceDocumentKey  String?
  insuranceVerified     Boolean   @default(false)
  insuranceVerifiedAt   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  applications     Application[]
  payments         Payment[]
  waitlistEntries  Waitlist[]
  reviewedApps     Application[] @relation("ReviewedBy")
}

model Vehicle {
  id               String        @id @default(uuid())
  slug             String        @unique
  make             String
  model            String
  year             Int
  type             VehicleType
  status           VehicleStatus @default(available)
  weeklyPrice      Int
  depositAmount    Int
  transmission     Transmission
  fuelType         FuelType
  seats            Int
  mpgCity          Int?
  mpgHighway       Int?
  mileagePolicy    String
  minRentalDays    Int           @default(7)
  features         String[]
  uberEligible     Boolean       @default(false)
  lyftEligible     Boolean       @default(false)
  deliveryEligible Boolean       @default(false)
  isFeatured       Boolean       @default(false)
  description      String?
  images           String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  applications     Application[]
  waitlistEntries  Waitlist[]
}

model Application {
  id              String            @id @default(uuid())
  userId          String
  vehicleId       String
  status          ApplicationStatus @default(draft)
  personalInfo    Json?
  licenseDocKey   String?
  insuranceDocKey String?
  adminNotes      String?
  reviewedAt      DateTime?
  reviewedById    String?
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])
  reviewedBy      User?             @relation("ReviewedBy", fields: [reviewedById], references: [id])
  payments        Payment[]
}

model Payment {
  id                    String        @id @default(uuid())
  applicationId         String
  userId                String
  type                  PaymentType
  amountCents           Int
  currency              String        @default("usd")
  status                PaymentStatus @default(pending)
  stripePaymentIntentId String?
  stripeChargeId        String?
  paidAt                DateTime?
  receiptEmailSentAt    DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  application           Application   @relation(fields: [applicationId], references: [id])
  user                  User          @relation(fields: [userId], references: [id])
}

model Waitlist {
  id          String    @id @default(uuid())
  vehicleId   String
  userId      String?
  name        String?
  email       String
  phone       String?
  notifiedAt  DateTime?
  position    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
}
