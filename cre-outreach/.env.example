# ─────────────────────────────────────────────────────────────────────────────
# cre-outreach configuration. Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Hunter.io — used to find email addresses for each domain.
# Get a key at https://hunter.io/api-keys
HUNTER_API_KEY=

# Anthropic — used to write the cold emails.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model + effort are optional; these are sensible defaults.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_EFFORT=medium

# Google OAuth — used to create Gmail drafts.
# Create an OAuth client ID (type: "Desktop app" is easiest) at
# https://console.cloud.google.com/apis/credentials and enable the Gmail API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local port the one-time `npm run auth` flow listens on for the OAuth redirect.
# Add http://localhost:5555/oauth2callback as an authorized redirect URI.
GOOGLE_OAUTH_PORT=5555

# ── Who you are (drives the personalization of every email) ──────────────────
# NOTE: sender name ("Jatin Bottu"), phone ("470-991-9274"), and the
# "ask for a quick call" CTA are HARDCODED in the app (src/config.ts) and
# always appear — they are not configured here.
#
# A one-line background the model will weave in naturally. Edit to taste.
SENDER_BACKGROUND=I'm a Georgia Tech student with prior hands-on experience applying AI in commercial real estate.
# What you're actually reaching out about — the value/offer. BE SPECIFIC.
# This is the single most important field for response rate.
SENDER_PITCH=I build AI tools that help multifamily and commercial real estate operators surface insights from their portfolio data faster, and I'd love to learn how your team handles this today.
# Optional: a scheduling link to include in the call-to-action.
SENDER_CALENDAR_LINK=

# ── Tuning (optional) ────────────────────────────────────────────────────────
# Extra comma-separated title keywords that should rank a contact higher.
TARGET_ROLE_KEYWORDS=
# Minimum Hunter confidence (0-100) to accept a contact. Below this => flagged.
MIN_CONFIDENCE=50
